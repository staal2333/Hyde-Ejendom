# ============================================================
# Ejendom AI – Miljøvariabler
# Kopier til .env.local og erstat placeholders med dine værdier
# ============================================================

# ─── HubSpot (påkrævet for pipeline) ────────────────────────
# HubSpot → Settings → Integrations → Private Apps → Create
# Scopes: crm.objects.companies.read/write, crm.objects.contacts.read/write
HUBSPOT_ACCESS_TOKEN=pat-na1-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ─── OpenAI (påkrævet for research og AI-udkast) ──────────────
# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o-mini

# ─── Cron / sikkerhed ───────────────────────────────────────
# Bruges til at sikre /api/run-research (Authorization: Bearer <denne værdi>)
CRON_SECRET=din-hemmelige-streng

# ─── Gmail (OAuth2 – delt Client ID/Secret, per-konto refresh tokens) ──
# Opret ét OAuth2 app i Google Cloud Console
GMAIL_CLIENT_ID=xxxx.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=GOCSPX-xxxx

# Konto 1 (primær)
GMAIL_1_EMAIL=sebastian.staal@hydemedia.dk
GMAIL_1_NAME=Sebastian – Hyde Media
GMAIL_1_REFRESH_TOKEN=1//xxxx

# Konto 2
GMAIL_2_EMAIL=ma@hydemedia.dk
GMAIL_2_NAME=Ma – Hyde Media
GMAIL_2_REFRESH_TOKEN=1//xxxx

# Konto 3
GMAIL_3_EMAIL=louis.lerche@hydemedia.dk
GMAIL_3_NAME=Louis – Hyde Media
GMAIL_3_REFRESH_TOKEN=1//xxxx

# Backward compat (bruges hvis GMAIL_1_* ikke er sat)
GMAIL_FROM_EMAIL=sebastian.staal@hydemedia.dk
GMAIL_FROM_NAME=Sebastian – Hyde Media
GMAIL_REFRESH_TOKEN=1//xxxx

# Valgfrit: antal mails per time (standard 200)
# EMAIL_RATE_LIMIT_PER_HOUR=200

# ─── Meta Ad Library (Lead Sourcing) ────────────────────────
# Format: App ID + lodret streg + App Secret (ingen mellemrum)
# Meta for Developers → din app → Settings → Basic → App ID & App Secret
META_AD_LIBRARY_ACCESS_TOKEN=APP_ID|APP_SECRET
# Valgfrit (standard v22.0). Ved kode 1-fejl kan du prøve META_GRAPH_API_VERSION=v21.0
# META_GRAPH_API_VERSION=v22.0

# ─── Valgfrie: Tone of Voice / eksempel-mails ───────────────
# TONE_OF_VOICE=Professionel men personlig...
# EXAMPLE_EMAILS=Eksempel 1: ...

# ─── Valgfrie: Supabase (mail-tråde, staging, OOH) ──────────
# NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── Valgfrie: CVR / DAWA (har standard-URLs) ──────────────
# CVR_API_URL=https://cvrapi.dk/api
# CVR_USER_AGENT=EjendomAI/1.0
# DAWA_API_URL=https://dawa.aws.dk
